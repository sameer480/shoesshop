# MongoDB connection string (use Atlas in production)
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/shoedb

# JWT signing secret (any long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Email (Gmail App Password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Google OAuth
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret

# Dummy merchant UPI (replace with your real UPI to receive money)
MERCHANT_UPI_ID=shoehub@upi
MERCHANT_NAME=ShoeHub Store
MERCHANT_BANK=DummyBank Demo
MERCHANT_ACCOUNT=1234567890123
MERCHANT_IFSC=DUMM0000123
